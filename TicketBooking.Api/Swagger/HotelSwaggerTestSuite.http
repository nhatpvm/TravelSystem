@baseUrl = http://localhost:5183
@apiVersion = 1

@tenantId = REPLACE_TENANT_GUID
@adminToken = REPLACE_ADMIN_JWT
@qlksToken = REPLACE_QLKS_JWT

@ariFrom = 2026-04-10
@ariTo = 2026-04-12
@publicCheckIn = 2026-04-10
@publicCheckOut = 2026-04-12

@qlksHotelId = REPLACE_AFTER_CREATE
@qlksHotelSlug = swagger-qlks-hotel-001
@hiddenHotelId = REPLACE_AFTER_CREATE
@hiddenHotelSlug = swagger-hidden-hotel-001
@adminHotelId = REPLACE_AFTER_CREATE
@adminHotelSlug = swagger-admin-hotel-001

@bedTypeId = REPLACE_AFTER_CREATE
@mealPlanId = REPLACE_AFTER_CREATE
@hotelAmenityId = REPLACE_AFTER_CREATE
@roomAmenityId = REPLACE_AFTER_CREATE

@qlksCancellationPolicyId = REPLACE_AFTER_CREATE
@qlksCheckInOutRuleId = REPLACE_AFTER_CREATE
@qlksPropertyPolicyId = REPLACE_AFTER_CREATE
@qlksRoomTypeId = REPLACE_AFTER_CREATE
@qlksRatePlanId = REPLACE_AFTER_CREATE
@qlksRatePlanRoomTypeId = REPLACE_AFTER_GET
@qlksExtraServiceId = REPLACE_AFTER_CREATE

@hotelContactSecondaryId = REPLACE_AFTER_CREATE
@hotelImageSecondaryId = REPLACE_AFTER_CREATE

@adminCancellationPolicyId = REPLACE_AFTER_CREATE
@adminCheckInOutRuleId = REPLACE_AFTER_CREATE
@adminPropertyPolicyId = REPLACE_AFTER_CREATE
@adminRoomTypeId = REPLACE_AFTER_CREATE
@adminRoomTypePolicyId = REPLACE_AFTER_CREATE
@adminRoomTypeImageSecondaryId = REPLACE_AFTER_CREATE
@adminRatePlanId = REPLACE_AFTER_CREATE
@adminRatePlanRoomTypeId = REPLACE_AFTER_GET
@adminExtraServiceId = REPLACE_AFTER_CREATE
@promoOverrideId = REPLACE_AFTER_CREATE

@seedReviewId = REPLACE_EXISTING_REVIEW_ID
@seedReviewHotelId = REPLACE_EXISTING_REVIEW_HOTEL_ID

# HOTEL SWAGGER REGRESSION SUITE
# Suite nay da doi chieu voi runtime that, khong con la smoke suite.
# Chi dung X-TenantId. Hotel review can review seed co san.
# Regression da fix va duoc giu trong suite:
# - replace/update links o qlks/admin room-types, rate-plans, hotel-amenity links, bed links, room-amenity links phai idempotent
# - Swagger-only optional fields o bed type, meal plan, hotel contact, meal-plan link khong duoc lam runtime 400
# - room-type-image inactive phai bi chan khi set-primary

### QLKS - Create active hotel - expect 201
POST {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Content-Type: application/json

{"code":"QLKS-HTL-SWAGGER-001","name":"Swagger QLKS Hotel 001","slug":"{{qlksHotelSlug}}","addressLine":"123 Swagger Street","city":"Ho Chi Minh City","province":"Ho Chi Minh","countryCode":"VN","latitude":10.7769,"longitude":106.7009,"timeZone":"Asia/Ho_Chi_Minh","shortDescription":"Hotel tao bang regression swagger suite","descriptionMarkdown":"## Swagger QLKS Hotel","descriptionHtml":"<h2>Swagger QLKS Hotel</h2>","starRating":4,"status":2,"defaultCheckInTime":"14:00:00","defaultCheckOutTime":"12:00:00","phone":"0900000001","email":"qlks-hotel@example.com","websiteUrl":"https://example.com/qlks-hotel","coverImageUrl":"https://example.com/images/qlks-cover.jpg","policiesJson":"{\"pets\":\"not-allowed\"}","metadataJson":"{\"source\":\"swagger-suite\"}","isActive":true}

### QLKS - Create hidden draft hotel - expect 201
POST {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Content-Type: application/json

{"code":"QLKS-HTL-HIDDEN-001","name":"Swagger Hidden Hotel 001","slug":"{{hiddenHotelSlug}}","addressLine":"999 Hidden Street","city":"Ho Chi Minh City","province":"Ho Chi Minh","countryCode":"VN","timeZone":"Asia/Ho_Chi_Minh","shortDescription":"Hidden draft hotel","starRating":3,"status":1,"phone":"0900000999","email":"hidden-hotel@example.com","isActive":true}

### QLKS - List hotels - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels?page=1&pageSize=20
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Accept: application/json

### QLKS - Get hotel by id - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels/{{qlksHotelId}}
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Accept: application/json

### QLKS - Update hotel with clear flags - expect 200
PUT {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels/{{qlksHotelId}}
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Content-Type: application/json

{"name":"Swagger QLKS Hotel 001 Updated","shortDescription":"Updated by swagger suite","clearLatitude":true,"clearLongitude":true,"clearDefaultCheckInTime":true,"clearDefaultCheckOutTime":true,"clearCoverMediaAssetId":true,"coverImageUrl":"https://example.com/images/qlks-cover-updated.jpg","isActive":true}

### QLKS - Negative update clear flag conflict - expect 400
PUT {{baseUrl}}/api/v{{apiVersion}}/qlks/hotels/{{qlksHotelId}}
Authorization: Bearer {{qlksToken}}
X-TenantId: {{tenantId}}
Content-Type: application/json

{"locationId":"11111111-1111-1111-1111-111111111111","clearLocationId":true}

### Public - Search hotels - active visible, draft hidden excluded - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels?page=1&pageSize=20&q=swagger
Accept: application/json

### Public - Get active hotel by id - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/{{qlksHotelId}}
Accept: application/json

### Public - Get active hotel by slug - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/slug/{{qlksHotelSlug}}
Accept: application/json

### Public - Hidden draft by id must 404
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/{{hiddenHotelId}}
Accept: application/json

### Public - Gallery by id - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/{{qlksHotelId}}/gallery
Accept: application/json

### Public - Reviews by slug - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/slug/{{qlksHotelSlug}}/reviews?page=1&pageSize=10
Accept: application/json

### Public - Availability by slug - expect 200
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/slug/{{qlksHotelSlug}}/availability?checkInDate={{publicCheckIn}}&checkOutDate={{publicCheckOut}}&adults=2&children=0&rooms=2
Accept: application/json

### Public - Hidden draft availability must 404
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/slug/{{hiddenHotelSlug}}/availability?checkInDate={{publicCheckIn}}&checkOutDate={{publicCheckOut}}&adults=2&children=0&rooms=1
Accept: application/json

### Public - Invalid availability date order - expect 400
GET {{baseUrl}}/api/v{{apiVersion}}/hotels/slug/{{qlksHotelSlug}}/availability?checkInDate={{ariTo}}&checkOutDate={{ariFrom}}&adults=2&children=0&rooms=1
Accept: application/json

